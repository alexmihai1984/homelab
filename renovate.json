{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "extends": ["config:recommended"],
  "prConcurrentLimit": 50,

  "kubernetes" :{
    "fileMatch": ["^k8s/.+\\.ya?ml$"]
  },

  "packageRules": [
    {
      "description": "Disable private Docker registry (homelab images)",
      "matchDatasources": ["docker"],
      "matchPackagePrefixes": ["docker.alexmihai.rocks/"],
      "enabled": false
    },
    {
      "description": "Disable entire Booklore stack",
      "matchManagers": ["docker-compose"],
      "matchFileNames": ["docker/booklore/**"],
      "enabled": false
    },
    {
      "description": "Disable entire Crowdsec stack",
      "matchManagers": ["docker-compose"],
      "matchFileNames": ["docker/crowdsec/**"],
      "enabled": false
    },
    {
      "description": "Disable entire Kavita stack",
      "matchManagers": ["docker-compose"],
      "matchFileNames": ["docker/kavita/**"],
      "enabled": false
    }
  ]
}